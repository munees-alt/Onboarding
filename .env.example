# Copy to .env.local and fill in. Never commit .env.local.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

DATABASE_URL=
DIRECT_URL=

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CADENCE_ENCRYPTION_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (one app for all members). Redirect URI: {APP_URL}/api/connect/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Shared parent folder where Cadence creates each client folder.
GOOGLE_DRIVE_ROOT_FOLDER_ID=1r-FdD4NRrMvKD4tITiY6PTglo1z_Cy4_

# Zoho OAuth (Server-based app). Redirect: {APP_URL}/api/connect/zoho/callback
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
